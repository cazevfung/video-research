{
  "name": "youtube-batch-summary-backend",
  "version": "1.0.0",
  "description": "Backend service for YouTube batch summary generation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node scripts/kill-port.js 5000 && nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "ts-node scripts/test-api.ts",
    "test:research": "ts-node scripts/test-research.ts",
    "simulate:style-guide": "ts-node scripts/simulate-style-guide.ts",
    "test:metadata": "ts-node scripts/test-metadata.ts",
    "test:dashscope": "ts-node scripts/test-dashscope.ts",
    "dev:setup": "ts-node scripts/dev-setup.ts",
    "dev:reset": "ts-node scripts/dev-reset.ts",
    "dev:seed": "ts-node scripts/dev-seed.ts",
    "dev:validate": "ts-node scripts/dev-validate.ts",
    "verify-migration": "ts-node scripts/verify-user-migration.ts",
    "rollout:check": "ts-node scripts/gradual-rollout.ts"
  },
  "keywords": [
    "youtube",
    "summary",
    "ai",
    "transcript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.10.6",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1"
  }
}
