# Backend API URL
# Development: http://localhost:5000
# Production: https://your-cloud-run-url.run.app
NEXT_PUBLIC_API_URL=http://localhost:5000

# Firebase Authentication Configuration
# Feature flag to enable/disable Firebase Auth (default: false)
NEXT_PUBLIC_USE_FIREBASE_AUTH=false

# Firebase Client SDK Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google OAuth (optional - for Passport.js authentication when USE_FIREBASE_AUTH=false)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# NextAuth Configuration (optional - for future authentication)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Development: Skip authentication (set to "true" to bypass auth during development)
NEXT_PUBLIC_SKIP_AUTH=false

# Development User Configuration (must match backend DEV_USER_* values)
# Used when NEXT_PUBLIC_SKIP_AUTH=true
NEXT_PUBLIC_DEV_USER_ID=dev-user-id
NEXT_PUBLIC_DEV_USER_EMAIL=dev@example.com
NEXT_PUBLIC_DEV_USER_NAME=Development User# Phase 7: API Configuration (Optional - uses sensible defaults)
# API cache duration in milliseconds (default: 30000)
NEXT_PUBLIC_API_CACHE_DURATION_MS=30000

# User data polling interval in milliseconds (default: 30000)
NEXT_PUBLIC_USER_DATA_POLLING_INTERVAL_MS=30000

# Maximum cache entries before cleanup (default: 50)
NEXT_PUBLIC_API_MAX_CACHE_ENTRIES=50

# API retry configuration
# Maximum number of retries for failed requests (default: 3)
NEXT_PUBLIC_API_MAX_RETRIES=3

# Initial retry delay in milliseconds (default: 1000)
NEXT_PUBLIC_API_RETRY_DELAY_MS=1000

# Maximum retry delay in milliseconds (default: 10000)
NEXT_PUBLIC_API_MAX_RETRY_DELAY_MS=10000# Retry multiplier for exponential backoff (default: 2.0)
NEXT_PUBLIC_API_RETRY_MULTIPLIER=2.0

# Request timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT_MS=30000

# API default port for localhost fallback (default: 5000)
NEXT_PUBLIC_API_DEFAULT_PORT=5000

# Share Feature Configuration (Phase 4)
# Frontend URL for share link generation (optional)
# Development: Leave empty or unset (defaults to http://localhost:3000/shared)
# Production: Set to your Firebase Hosting URL (e.g., https://video-research-40c4b.web.app)
# NEXT_PUBLIC_FRONTEND_URL=https://video-research-40c4b.web.app

# Frontend port for development share links (optional, default: 3000)
# NEXT_PUBLIC_FRONTEND_PORT=3000

# Phase 1: Rate Limiting Configuration (Optional - uses sensible defaults)
# Default retry-after duration in seconds when backend doesn't provide one (default: 900 = 15 minutes)
NEXT_PUBLIC_RATE_LIMIT_DEFAULT_RETRY_AFTER_SECONDS=900

# Maximum pause duration in seconds for rate limit pauses (default: 300 = 5 minutes)
NEXT_PUBLIC_RATE_LIMIT_MAX_PAUSE_SECONDS=300

# Phase 1: Toast Notification Configuration (Optional - uses sensible defaults)
# Default toast duration in milliseconds (default: 5000 = 5 seconds)
NEXT_PUBLIC_TOAST_DEFAULT_DURATION_MS=5000

# Auth error toast duration in milliseconds (0 = don't auto-dismiss) (default: 0)
NEXT_PUBLIC_TOAST_AUTH_ERROR_DURATION_MS=0

# Phase 1: Task Management Configuration (Optional - uses sensible defaults)
# Task restoration timeout in milliseconds (default: 300000 = 5 minutes)
# Tasks older than this won't be restored from sessionStorage on page refresh
NEXT_PUBLIC_TASK_RESTORATION_TIMEOUT_MS=300000

# Phase 2: Exponential Backoff Configuration (Optional - uses sensible defaults)
# Maximum delay cap in milliseconds (default: 240000 = 4 minutes)
NEXT_PUBLIC_BACKOFF_MAX_DELAY_MS=240000

# Exponential backoff multiplier (default: 2.0)
NEXT_PUBLIC_BACKOFF_MULTIPLIER=2.0

# Enable/disable jitter in exponential backoff (default: true)
NEXT_PUBLIC_BACKOFF_JITTER_ENABLED=true

# Jitter factor as percentage (0-1) (default: 0.2 = ±20%)
NEXT_PUBLIC_BACKOFF_JITTER_FACTOR=0.2

# Phase 2: Circuit Breaker Configuration (Optional - uses sensible defaults)
# Number of failures before opening circuit (default: 5)
NEXT_PUBLIC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Number of successes to close from half-open state (default: 2)
NEXT_PUBLIC_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# Timeout in milliseconds before trying half-open state (default: 60000 = 1 minute)
NEXT_PUBLIC_CIRCUIT_BREAKER_TIMEOUT_MS=60000

# Phase 3: Request Deduplication Configuration (Optional - uses sensible defaults)
# Cache timeout in milliseconds for request deduplication (default: 5000 = 5 seconds)
NEXT_PUBLIC_REQUEST_DEDUP_CACHE_TIMEOUT_MS=5000

# Phase 3: Metrics Collection Configuration (Optional - uses sensible defaults)
# Maximum number of metric events to retain in memory (default: 1000)
NEXT_PUBLIC_METRICS_MAX_EVENTS=1000