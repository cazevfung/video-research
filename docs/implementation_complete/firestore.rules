rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to get user document ID from Firebase Auth UID
    function getUserDocId() {
      return firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data.id;
    }
    
    // Pricing configuration - public read access
    match /pricing_config/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend (Admin SDK) can write
    }
    
    // User credits - owner only
    match /user_credits/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Credit transactions - owner only
    match /credit_transactions/{transactionId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow write: if false; // Only backend (Admin SDK) can write
    }
    
    // Tier requests - owner can read their own, write is restricted
    match /tier_requests/{requestId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Only backend (Admin SDK) can update/delete
    }
    
    // Users collection - owner only
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Summaries collection - owner only
    match /summaries/{summaryId} {
      allow read, write: if isAuthenticated() && 
        resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.user_id == request.auth.uid;
    }
    
    // Batch costs - owner only (read-only for users)
    match /batch_costs/{batchId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow write: if false; // Only backend (Admin SDK) can write
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

